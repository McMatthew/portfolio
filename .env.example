# EmailJS — copia in .env e compila con i tuoi valori
# I valori reali vanno in GitHub → Settings → Secrets and variables → Actions
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_CONFIRM=template_xxxxxxx
VITE_EMAILJS_TEMPLATE_INTERNAL=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxxx
